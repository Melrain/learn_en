# MongoDB 连接字符串
# 本地开发（Docker）：docker-compose up -d 后使用
MONGODB_URI=mongodb://admin:learn_en_dev@localhost:27017/learn_en?authSource=admin

# 阿里云语音评测（智能科教内容生成平台）
# 应用 ID，暴露到客户端用于 EngineEvaluat 初始化，控制台获取
NEXT_PUBLIC_ALIYUN_APP_ID=your_application_id
# 用户标识，暴露到客户端
NEXT_PUBLIC_ALIYUN_USER_ID=your_user_id
# 应用密钥，仅服务端用于鉴权签名，控制台获取，切勿暴露
ALIYUN_APP_SECRET=your_app_secret

# 阿里云智能语音 TTS（与口语评测不同产品，需单独开通）
# 主账号 AccessKey，用于获取 TTS Token，控制台：https://ram.console.aliyun.com
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
# TTS 项目 AppKey，控制台：https://nls-portal.console.aliyun.com/applist
ALIYUN_TTS_APPKEY=your_tts_appkey

# LangGraph / DeepSeek（AI Agent）
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
